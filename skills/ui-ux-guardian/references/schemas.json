{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["target_pages", "baseline_path", "threshold_percent"],
      "properties": {
        "target_pages": { "type": "array", "items": { "type": "string" } },
        "baseline_path": { "type": "string", "minLength": 1 },
        "threshold_percent": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "critical_count", "report_path"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "critical_count": { "type": "integer", "minimum": 0 },
        "report_path": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
