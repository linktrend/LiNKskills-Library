{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["views", "ctr", "sentiment"],
      "properties": {
        "views": { "type": "array", "items": { "type": "integer" } },
        "ctr": { "type": "array", "items": { "type": "integer" } },
        "sentiment": { "type": "array", "items": { "type": "string" } },
        "window": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "high_signal_feedback", "recommended_actions"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "high_signal_feedback": { "type": "array", "items": { "type": "object" } },
        "recommended_actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
