{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["artifact_path", "acceptance_criteria"],
      "properties": {
        "artifact_path": { "type": "string", "minLength": 1 },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "agent_id": { "type": "string" },
        "project_id": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "defect_count", "severity_summary"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "defect_count": { "type": "integer", "minimum": 0 },
        "severity_summary": { "type": "object" },
        "bug_history_updated": { "type": "boolean" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
