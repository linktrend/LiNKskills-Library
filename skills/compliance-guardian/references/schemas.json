{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["platforms", "content_manifest"],
      "properties": {
        "platforms": { "type": "array", "items": { "type": "string", "enum": ["youtube", "meta"] } },
        "content_manifest": { "type": "string", "minLength": 1 },
        "requires_ai_disclosure": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "decision", "violations"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "decision": { "type": "string", "enum": ["PASS", "FAIL"] },
        "violations": { "type": "array", "items": { "type": "object" } },
        "required_disclosures": { "type": "array", "items": { "type": "string" } }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
