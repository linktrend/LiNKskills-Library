{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["prd_path", "market_segment", "growth_goal"],
      "properties": {
        "prd_path": { "type": "string", "minLength": 1 },
        "market_segment": { "type": "string", "minLength": 2 },
        "growth_goal": { "type": "string", "minLength": 3 },
        "budget_ceiling": { "type": "integer", "minimum": 0 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "artifact_path", "seo_targets", "ad_spend_projection", "funnel_architecture"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "artifact_path": { "type": "string", "minLength": 1 },
        "seo_targets": { "type": "array", "items": { "type": "object" } },
        "ad_spend_projection": { "type": "object" },
        "funnel_architecture": { "type": "object" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
