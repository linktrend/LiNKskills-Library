{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["progress_sources", "audit_window"],
      "properties": {
        "progress_sources": { "type": "array", "items": { "type": "string" } },
        "audit_window": { "type": "string", "minLength": 3 },
        "include_risk_matrix": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "report_markdown", "health_summary"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "report_markdown": { "type": "string", "minLength": 10 },
        "health_summary": { "type": "object" },
        "source_count": { "type": "integer", "minimum": 0 }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
