{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["agent_id", "project_id", "workflow_name", "objective", "trigger_type"],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "workflow_name": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 5 },
        "trigger_type": {
          "type": "string",
          "enum": ["webhook", "schedule", "manual", "event"]
        },
        "test_payload": { "type": "object" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "workflow_id", "activated", "tested"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["SUCCESS", "FAILED"]
        },
        "workflow_id": { "type": "string", "minLength": 1 },
        "activated": { "type": "boolean" },
        "tested": { "type": "boolean" },
        "execution_id": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
