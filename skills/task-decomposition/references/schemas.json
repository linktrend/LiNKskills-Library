{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["objective", "constraints"],
      "properties": {
        "objective": { "type": "string", "minLength": 5 },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "deadline": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "atomic_tasks"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "atomic_tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task_id", "objective", "verification"],
            "properties": {
              "task_id": { "type": "string" },
              "objective": { "type": "string" },
              "verification": { "type": "string" }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
