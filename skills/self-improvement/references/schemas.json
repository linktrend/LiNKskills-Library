{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["ledger_path", "analysis_window"],
      "properties": {
        "ledger_path": { "type": "string", "minLength": 1 },
        "analysis_window": { "type": "string" },
        "feature_requests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "proposals"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "proposals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target", "proposed_change", "rollback_plan", "version_delta"],
            "properties": {
              "target": { "type": "string" },
              "proposed_change": { "type": "string" },
              "rollback_plan": { "type": "string" },
              "version_delta": { "type": "string" }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
