{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["lead_updates", "finance_snapshot", "sync_time"],
      "properties": {
        "lead_updates": { "type": "array", "items": { "type": "object" } },
        "finance_snapshot": { "type": "string", "minLength": 1 },
        "sync_time": { "type": "string", "minLength": 3 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "wins", "blockers", "financial_health", "briefing_time"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "wins": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "financial_health": { "type": "object" },
        "briefing_time": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
