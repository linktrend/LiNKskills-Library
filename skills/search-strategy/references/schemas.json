{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["question", "confidence_threshold", "max_cost_tier"],
      "properties": {
        "question": { "type": "string", "minLength": 5 },
        "confidence_threshold": { "type": "number" },
        "max_cost_tier": {
          "type": "string",
          "enum": ["web", "neural", "brief", "social"]
        },
        "deep_research": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "tier_used", "confidence", "findings"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "tier_used": { "type": "string" },
        "confidence": { "type": "number" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "source_pointer"],
            "properties": {
              "title": { "type": "string" },
              "source_pointer": { "type": "string" }
            }
          }
        },
        "hitl_approval": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
