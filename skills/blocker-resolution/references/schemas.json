{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["worker_id", "progress_history"],
      "properties": {
        "worker_id": { "type": "string", "minLength": 1 },
        "progress_history": { "type": "array", "items": { "type": "object" } },
        "blocked_turn_threshold": { "type": "integer", "minimum": 1 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "rca_triggered", "actions"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "rca_triggered": { "type": "boolean" },
        "actions": { "type": "array", "items": { "type": "object" } },
        "root_causes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
