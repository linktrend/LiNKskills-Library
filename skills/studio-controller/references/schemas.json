{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["revenue_source", "expense_source", "window"],
      "properties": {
        "revenue_source": { "type": "string", "minLength": 1 },
        "expense_source": { "type": "string", "minLength": 1 },
        "window": { "type": "string", "minLength": 3 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "reports", "reconciliation_status", "lsl_finance_logged"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "reports": { "type": "object" },
        "reconciliation_status": { "type": "string", "enum": ["MATCHED", "MISMATCH", "PARTIAL"] },
        "lsl_finance_logged": { "type": "boolean" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
