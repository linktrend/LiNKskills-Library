{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["claims"],
      "properties": {
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id", "claim_text"],
            "properties": {
              "claim_id": { "type": "string" },
              "claim_text": { "type": "string", "minLength": 3 }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "citations"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id", "source_type", "source_pointer"],
            "properties": {
              "claim_id": { "type": "string" },
              "source_type": { "type": "string", "enum": ["memory", "search", "file"] },
              "source_pointer": { "type": "string", "minLength": 1 },
              "confidence": { "type": "string" }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
