{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["asset_paths", "prd_path", "brand_guidelines_path"],
      "properties": {
        "asset_paths": { "type": "array", "items": { "type": "string" } },
        "prd_path": { "type": "string", "minLength": 1 },
        "brand_guidelines_path": { "type": "string", "minLength": 1 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "gate", "findings"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "gate": { "type": "string", "enum": ["PASS", "FAIL"] },
        "findings": { "type": "array", "items": { "type": "object" } },
        "revision_logic": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
