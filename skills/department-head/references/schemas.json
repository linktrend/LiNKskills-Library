{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["progress_files", "objective"],
      "properties": {
        "progress_files": { "type": "array", "items": { "type": "string" } },
        "objective": { "type": "string", "minLength": 5 },
        "priority_window": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "directives", "risk_flags"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "directives": { "type": "array", "items": { "type": "object" } },
        "risk_flags": { "type": "array", "items": { "type": "string" } },
        "handoff_summary": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
