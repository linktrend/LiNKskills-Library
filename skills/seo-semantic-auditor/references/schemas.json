{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["competitors", "target_topics"],
      "properties": {
        "competitors": { "type": "array", "items": { "type": "string" } },
        "target_topics": { "type": "array", "items": { "type": "string" } },
        "geo": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "content_gaps"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "content_gaps": { "type": "array", "items": { "type": "object" } },
        "evidence_index": { "type": "array", "items": { "type": "object" } }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
