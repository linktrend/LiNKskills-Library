{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["platforms", "schedule_window", "campaign_goal"],
      "properties": {
        "platforms": { "type": "array", "items": { "type": "string", "enum": ["youtube", "tiktok", "x"] } },
        "schedule_window": { "type": "string", "minLength": 3 },
        "campaign_goal": { "type": "string", "minLength": 3 }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "schedule_plan", "comment_ops", "support_to_sales_funnel"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "schedule_plan": { "type": "array", "items": { "type": "object" } },
        "comment_ops": { "type": "object" },
        "support_to_sales_funnel": { "type": "object" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
