{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["prd_path", "factory_type"],
      "properties": {
        "prd_path": { "type": "string", "minLength": 1 },
        "factory_type": { "type": "string", "enum": ["saas", "web"] },
        "release_target": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "backlog_items", "definition_of_done"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "backlog_items": { "type": "array", "items": { "type": "object" } },
        "definition_of_done": {
          "type": "object",
          "required": ["qa_signoff_required"],
          "properties": {
            "qa_signoff_required": { "type": "boolean" },
            "checks": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": { "type": "string", "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$" },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"] },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
