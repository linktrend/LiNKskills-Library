{
  "definitions": {
    "input": {
      "type": "object",
      "required": ["draft", "requirements"],
      "properties": {
        "draft": { "type": "string", "minLength": 5 },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "risk_level": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["status", "findings", "corrected_output"],
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "message"],
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high"] },
              "message": { "type": "string" }
            }
          }
        },
        "corrected_output": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["task_id", "workflow_step", "status", "variables", "last_updated"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{4}-[A-Z0-9]+-\\d{6}$"
        },
        "workflow_step": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": {
          "type": "string",
          "enum": ["INITIALIZED", "IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "FAILED"]
        },
        "variables": { "type": "object" },
        "last_updated": { "type": "string" },
        "seek_index": { "type": "object" }
      }
    }
  }
}
